# ──────────────────────────────────────────────────────
# Kalima.fun — Environment Variables
# Copy this file to .env.local and fill in the values.
# ──────────────────────────────────────────────────────

# ── Firebase (client-side — public) ──────────────────
# These are already hardcoded in src/lib/firebase.ts.
# No action required unless you are creating a new project.

# ── Firebase Cloud Messaging (FCM) ───────────────────
# Required for push notifications.
# Get from Firebase Console → Project Settings → Cloud Messaging → Web Push certificates
NEXT_PUBLIC_FIREBASE_VAPID_KEY=

# ── Firebase Admin (server-side) ─────────────────────
# Required for admin stats API and Moyasar webhook.
# Either set this to the JSON content of your service account key,
# or deploy to GCP/Firebase App Hosting where Application Default Credentials work.
FIREBASE_SERVICE_ACCOUNT_KEY=

# ── Admin Dashboard ───────────────────────────────────
# Password for the /admin dashboard login.
# Auth is handled server-side via /api/admin/auth with a signed session cookie.
ADMIN_PASSWORD=

# ── Moyasar Payments (Pro subscriptions) ─────────────
# Get from https://dashboard.moyasar.com/apikeys
NEXT_PUBLIC_MOYASAR_KEY=
MOYASAR_SECRET_KEY=
MOYASAR_WEBHOOK_SECRET=

# ── Notifications API ─────────────────────────────────
# Secret for /api/notify bulk-notification endpoint.
NOTIFY_SECRET=

# ── App URL ───────────────────────────────────────────
# Used for generating absolute URLs (e.g. share links).
NEXT_PUBLIC_APP_URL=https://kalima.fun
